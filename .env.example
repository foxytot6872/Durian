# Copy this file to .env and fill in your secrets.
# Do NOT commit the real .env file to version control.

# OpenAI / LangChain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Local chatbot API server
CHATBOT_API_PORT=8000

# Google AI Studio / Gemini (optional)
# Gemini is opt-in. Leave ENABLE_GEMINI=false for OpenAI locally.
# To use Gemini, set ENABLE_GEMINI=true and MODEL_PROVIDER=gemini, then add your Google API key below.
# ENABLE_GEMINI=false
# MODEL_PROVIDER=openai
# GOOGLE_API_KEY=your_google_api_key_here
# GENAI_MODEL=text-bison-001

# Optional: Chroma/Vector DB settings
# CHROMA_API_KEY=
# CHROMA_SERVER_HOST=
# CHROMA_SERVER_PORT=

# Other third-party keys
# OTHER_API_KEY=
