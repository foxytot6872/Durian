# Copy this file to .env and fill in your secrets.
# Do NOT commit the real .env file to version control.

# OpenAI / LangChain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Local chatbot API server
CHATBOT_API_PORT=8000

# Google AI Studio / Gemini (optional)
# To use Gemini instead of OpenAI, set MODEL_PROVIDER=gemini and add your Google API key below
# GOOGLE_API_KEY=your_google_api_key_here
# GENAI_MODEL=text-bison-001

# Optional: Chroma/Vector DB settings
# CHROMA_API_KEY=
# CHROMA_SERVER_HOST=
# CHROMA_SERVER_PORT=

# Other third-party keys
# OTHER_API_KEY=
